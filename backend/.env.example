# =============================================================================
# MoodMentor Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Variables marked (required) must be set for the application to start.

# --- API Keys ---

# Google Gemini API Key (required)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# News API Key (optional - without it, fallback content is used)
# Get your API key from: https://newsapi.org/
NEWS_API_KEY=your_news_api_key_here

# --- Server Configuration ---

BACKEND_HOST=0.0.0.0
BACKEND_PORT=9000
FRONTEND_URL=http://localhost:5173

# --- Security ---

# API Key for endpoint authentication (optional)
# If not set, all API endpoints are public.
# Generate a secure random key:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your_secure_api_key_here

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Rate Limiting ---

# Set to "true" to disable rate limiting entirely
# DISABLE_RATE_LIMIT=false

# --- Logging ---

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Log format: "text" (human-readable) or "json" (structured)
LOG_FORMAT=text

# --- Database ---

# For local development (SQLite):
#   DATABASE_URL=sqlite+aiosqlite:///./moodmentor.db
# For Docker / production (PostgreSQL):
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./moodmentor.db

# --- Sentry (optional error tracking) ---

# Set a Sentry DSN to enable error monitoring
# SENTRY_DSN=https://your_dsn@sentry.io/your_project
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=1.0
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# --- Production Server (Gunicorn) ---

# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120
# GUNICORN_KEEPALIVE=5
# GUNICORN_MAX_REQUESTS=1000
# GUNICORN_MAX_REQUESTS_JITTER=50
